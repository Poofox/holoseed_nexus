{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sporecaster",
  "version": "0.1.0",
  "identifier": "com.foxasteria.sporecaster",
  "build": {
    "frontendDist": "../src-ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd src-ui && trunk serve --port 1420",
    "beforeBuildCommand": "cd src-ui && trunk build --release"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "🍄 Sporecaster",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
